@model QualityDoc.Models.Domain.Documento
@{
    ViewData["Title"] = Model.Titulo;
    var versiones = Model.Versiones.ToList();
    // "Versión de trabajo": la que está en proceso (borrador/revisión) o, si no hay, la vigente.
    // Las versiones rechazadas NO se muestran aquí; solo quedan en el historial.
    var enProceso = versiones.FirstOrDefault(v => v.Estado == "BORRADOR" || v.Estado == "EN_REVISION");
    var vigente = versiones.FirstOrDefault(v => v.EsVigente);
    var latest = enProceso ?? vigente;
    bool puedeEditar  = User.IsInRole("SUPERADMIN") || User.IsInRole("ADMIN") || User.IsInRole("REVISOR") || User.IsInRole("CREADOR");
    bool puedeAprobar = User.IsInRole("SUPERADMIN") || User.IsInRole("ADMIN") || User.IsInRole("REVISOR");
    bool esLector = !puedeEditar; // el Lector solo ve/descarga/previsualiza la versión vigente
}
@functions {
    static string Badge(string estado) => estado switch
    {
        "APROBADO" => "success",
        "EN_REVISION" => "warning text-dark",
        "BORRADOR" => "secondary",
        "RECHAZADO" => "danger",
        "OBSOLETO" => "dark",
        _ => "light text-dark"
    };
}

<a asp-action="Index" class="small text-decoration-none">&larr; Documentos</a>

<div class="d-flex justify-content-between align-items-start mt-1 mb-3">
    <div>
        <h3 class="mb-1">@Model.Titulo</h3>
        <div class="text-muted small">
            Área: <strong>@Model.Area?.Nombre</strong> ·
            Creado por: @Model.CreadoPor?.NombreCompleto ·
            @Model.CreadoEn.ToLocalTime().ToString("yyyy-MM-dd")
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Descripcion))
        {
            <p class="mt-2 mb-0">@Model.Descripcion</p>
        }
    </div>
    <div class="text-nowrap">
        @if (puedeEditar)
        {
            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">
                <i class="bi bi-pencil"></i> Editar datos
            </a>
        }
        @if (User.IsInRole("SUPERADMIN") || User.IsInRole("ADMIN"))
        {
            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#delModal">
                <i class="bi bi-trash"></i> Dar de baja
            </button>
        }
    </div>
</div>

@* ── Versión de trabajo + acciones del flujo ── *@
@if (latest != null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Versión de trabajo: <strong>@latest.VersionTag</strong>
                <span class="badge bg-@Badge(latest.Estado) ms-1">@latest.Estado</span>
                @if (latest.EsVigente) { <span class="badge bg-success ms-1">VIGENTE</span> }
            </span>
            @if (latest.RutaArchivo != null)
            {
                <span class="text-nowrap">
                    <button type="button" class="btn btn-sm btn-primary js-ver" data-version-id="@latest.Id" data-nombre="@latest.NombreArchivo">
                        <i class="bi bi-eye"></i> Ver
                    </button>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Download" asp-route-versionId="@latest.Id">
                        <i class="bi bi-download"></i> @latest.NombreArchivo
                    </a>
                </span>
            }
        </div>
        <div class="card-body">
            @if (latest.Estado == "BORRADOR" && puedeEditar)
            {
                <form asp-action="SubirArchivo" method="post" enctype="multipart/form-data" class="row g-2 align-items-end mb-3">
                    <input type="hidden" name="versionId" value="@latest.Id" />
                    <input type="hidden" name="documentoId" value="@Model.Id" />
                    <div class="col-md-7">
                        <label class="form-label small mb-0">Reemplazar / subir archivo</label>
                        <input type="file" name="archivo" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-secondary w-100"><i class="bi bi-upload"></i> Guardar archivo</button>
                    </div>
                </form>
                <form asp-action="EnviarRevision" method="post" onsubmit="return confirm('¿Enviar a revisión?');">
                    <input type="hidden" name="versionId" value="@latest.Id" />
                    <input type="hidden" name="documentoId" value="@Model.Id" />
                    <button class="btn btn-warning"><i class="bi bi-send"></i> Enviar a revisión</button>
                </form>
            }
            else if (latest.Estado == "EN_REVISION" && puedeAprobar)
            {
                <p class="mb-2 text-muted small">Este documento está esperando tu revisión.</p>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#revisarModal">
                    <i class="bi bi-clipboard-check"></i> Revisar documento
                </button>
            }
            else if (latest.Estado == "EN_REVISION")
            {
                <span class="text-muted">En revisión. Un revisor o admin debe aprobar o rechazar.</span>
            }
            else if (latest.Estado == "APROBADO" && puedeEditar)
            {
                <form asp-action="NuevaVersion" method="post" enctype="multipart/form-data" class="row g-2 align-items-end">
                    <input type="hidden" name="documentoId" value="@Model.Id" />
                    <div class="col-md-7">
                        <label class="form-label small mb-0">Nueva versión (subir archivo de reemplazo)</label>
                        <input type="file" name="archivo" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-primary w-100"><i class="bi bi-arrow-up-circle"></i> Crear nueva versión</button>
                    </div>
                    <div class="col-12"><div class="form-text">Crea una nueva edición en BORRADOR que pasará por revisión. Al aprobarla quedará vigente; la anterior vigente pasará a obsoleta.</div></div>
                </form>
            }
            else
            {
                <span class="text-muted">Sin acciones pendientes para tu rol.</span>
            }
        </div>
    </div>
}
else if (puedeEditar)
{
    @* No hay versión vigente ni en proceso (p.ej. la última quedó rechazada): se permite empezar una nueva. *@
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <p class="text-muted small mb-2">Este documento no tiene una versión vigente ni en proceso.</p>
            <form asp-action="NuevaVersion" method="post" enctype="multipart/form-data" class="row g-2 align-items-end">
                <input type="hidden" name="documentoId" value="@Model.Id" />
                <div class="col-md-7">
                    <label class="form-label small mb-0">Nueva versión (subir archivo)</label>
                    <input type="file" name="archivo" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary w-100"><i class="bi bi-arrow-up-circle"></i> Crear nueva versión</button>
                </div>
            </form>
        </div>
    </div>
}

@* ── Historial de versiones (filtrable por estado y nº de versión) ── *@
<h5>Historial de versiones <span class="text-muted small">(@versiones.Count)</span></h5>
<div class="row g-2 mb-2">
    <div class="col-md-3">
        <select id="fEstado" class="form-select form-select-sm">
            <option value="">Todos los estados</option>
            <option value="APROBADO">Aprobadas</option>
            <option value="RECHAZADO">Rechazadas</option>
            <option value="OBSOLETO">Obsoletas</option>
            <option value="BORRADOR">Borrador</option>
            <option value="EN_REVISION">En revisión</option>
        </select>
    </div>
    <div class="col-md-3">
        <input id="fVersion" class="form-control form-control-sm" placeholder="Buscar nº de versión (ej. 1.0)">
    </div>
</div>
<div class="table-responsive">
    <table class="table table-sm table-striped align-middle bg-white">
        <thead class="table-light">
            <tr><th>Versión</th><th>Estado</th><th>Tipo</th><th>Subido por</th><th>Fecha</th><th>Comentario</th><th></th></tr>
        </thead>
        <tbody id="histBody">
        @foreach (var v in versiones)
        {
            <tr data-estado="@v.Estado" data-version="@v.VersionTag">
                <td>
                    <span class="badge bg-light text-dark border">@v.VersionTag</span>
                    @if (v.EsVigente) { <span class="badge bg-success">vigente</span> }
                    @if (v.Estado == "OBSOLETO" && v.FueAprobada) { <span class="badge bg-secondary">aprobada antes</span> }
                </td>
                <td><span class="badge bg-@Badge(v.Estado)">@v.Estado</span></td>
                <td>@v.TipoArchivo</td>
                <td class="small">@v.SubidoPor?.NombreCompleto</td>
                <td class="small text-muted">@v.CreadoEn.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td class="small">@v.ComentarioRevision</td>
                <td class="text-end text-nowrap">
                    @if (v.RutaArchivo != null)
                    {
                        @if (!esLector || v.EsVigente)
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary js-ver" data-version-id="@v.Id" data-nombre="@v.NombreArchivo" title="Vista previa">
                                <i class="bi bi-eye"></i>
                            </button>
                        }
                        <button type="button" class="btn btn-sm btn-outline-info" onclick="verMetadatos(@v.Id)" title="Ver metadatos">
                            <i class="bi bi-info-circle"></i>
                        </button>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Download" asp-route-versionId="@v.Id" title="Descargar (app)">
                            <i class="bi bi-download"></i>
                        </a>
                        var nginxBase = ViewBag.NginxBase as string;
                        if (!string.IsNullOrEmpty(nginxBase))
                        {
                            <a class="btn btn-sm btn-outline-success" target="_blank" title="Abrir vía Nginx"
                               href="@(nginxBase.TrimEnd('/'))/@v.RutaArchivo">
                                <i class="bi bi-hdd-network"></i>
                            </a>
                        }
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<p id="histVacio" class="text-muted small d-none">No hay versiones que coincidan con el filtro.</p>

@* ── Modal de advertencia para dar de baja ── *@
<div class="modal fade" id="delModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle"></i> Dar de baja documento</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Seguro que quieres dar de baja <strong>@Model.Titulo</strong>?</p>
                <p class="small text-muted mb-0">Dejará de aparecer en los listados, en el portal y en las gráficas. No se borra físicamente (baja lógica), pero ya no estará disponible.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form asp-action="Eliminar" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Sí, dar de baja</button>
                </form>
            </div>
        </div>
    </div>
</div>

@* ── Modal de revisión (aprobar / rechazar por pasos) ── *@
@if (latest != null && latest.Estado == "EN_REVISION" && puedeAprobar)
{
    <div class="modal fade" id="revisarModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-clipboard-check"></i> Revisar documento — @latest.VersionTag</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" onclick="revVolver()"></button>
                </div>
                <div class="modal-body">
                  <div class="row g-3">
                    <div class="col-lg-7">
                        <div class="small text-muted mb-1"><i class="bi bi-file-earmark-text"></i> @latest.NombreArchivo</div>
                        <div id="revPreview" data-version-id="@latest.Id" data-nombre="@latest.NombreArchivo">
                            <div class="text-center text-muted py-5 border rounded">Cargando vista previa…</div>
                        </div>
                    </div>
                    <div class="col-lg-5">
                        <div id="revPaso1">
                            <p>¿Qué decisión tomas sobre esta versión?</p>
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-success" onclick="revElegir('aprobar')"><i class="bi bi-check-lg"></i> Aprobar</button>
                                <button type="button" class="btn btn-danger" onclick="revElegir('rechazar')"><i class="bi bi-x-lg"></i> Rechazar</button>
                            </div>
                        </div>

                        <form id="revAprobar" class="d-none" asp-action="Aprobar" method="post">
                            <input type="hidden" name="versionId" value="@latest.Id" />
                            <input type="hidden" name="documentoId" value="@Model.Id" />
                            <div class="alert alert-success py-2 small mb-2">Vas a <strong>aprobar</strong>. Quedará vigente; si es una edición, sube de versión mayor y la anterior pasa a obsoleta.</div>
                            <label class="form-label small">¿Por qué? (comentario, opcional)</label>
                            <textarea name="comentario" class="form-control mb-3" rows="3"></textarea>
                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="revVolver()">&larr; Volver</button>
                                <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Confirmar aprobación</button>
                            </div>
                        </form>

                        <form id="revRechazar" class="d-none" asp-action="Rechazar" method="post">
                            <input type="hidden" name="versionId" value="@latest.Id" />
                            <input type="hidden" name="documentoId" value="@Model.Id" />
                            <div class="alert alert-danger py-2 small mb-2">Vas a <strong>rechazar</strong> esta versión. Quedará marcada como RECHAZADA y subirá de número (p.ej. v2.0.0 → v2.1.0). Si hace falta, después se podrá subir una nueva versión.</div>
                            <label class="form-label small">¿Por qué? (motivo)</label>
                            <textarea name="comentario" class="form-control mb-3" rows="3"></textarea>
                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="revVolver()">&larr; Volver</button>
                                <button type="submit" class="btn btn-danger"><i class="bi bi-x-lg"></i> Confirmar rechazo</button>
                            </div>
                        </form>
                    </div>
                  </div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Modal de vista previa del documento ── *@
<div class="modal fade" id="previewModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-truncate"><i class="bi bi-file-earmark-text"></i> <span id="previewTitulo">Documento</span></h5>
                <a id="previewDescargar" class="btn btn-sm btn-outline-primary ms-auto me-2" href="#"><i class="bi bi-download"></i> Descargar</a>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="previewBody"><div class="text-center text-muted py-5">Cargando…</div></div>
            </div>
        </div>
    </div>
</div>

@* ── Modal de metadatos (se cargan en vivo desde MongoDB) ── *@
<div class="modal fade" id="metaModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-info-circle text-info"></i> Metadatos (en vivo desde MongoDB)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="metaBody"><div class="text-center text-muted py-3">Cargando…</div></div>
                <h6 class="text-muted small mt-3">JSON almacenado en Mongo</h6>
                <pre id="metaJson" class="bg-light p-2 small rounded" style="max-height:240px;overflow:auto"></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function verMetadatos(versionId) {
            document.getElementById('metaBody').innerHTML = '<div class="text-center text-muted py-3">Cargando…</div>';
            document.getElementById('metaJson').textContent = '';
            new bootstrap.Modal(document.getElementById('metaModal')).show();

            fetch('@Url.Action("Metadatos", "Documentos")?versionId=' + versionId)
                .then(r => r.json())
                .then(d => {
                    let rows = '';
                    rows += `<tr><th style="width:160px">Archivo</th><td>${d.archivo ?? ''}</td></tr>`;
                    rows += `<tr><th>Versión</th><td>${d.version ?? ''}</td></tr>`;
                    rows += `<tr><th>Tipo</th><td>${d.tipo ?? ''}</td></tr>`;
                    rows += `<tr><th>Tamaño</th><td>${(d.tamanioBytes ?? 0).toLocaleString()} bytes</td></tr>`;
                    rows += `<tr><th>Estado</th><td>${d.estado ?? ''}</td></tr>`;
                    if (d.nginxUrl) rows += `<tr><th>URL Nginx</th><td><a href="${d.nginxUrl}" target="_blank">${d.nginxUrl}</a></td></tr>`;
                    for (const k in (d.metadatos || {})) {
                        rows += `<tr><th>${k}</th><td>${d.metadatos[k]}</td></tr>`;
                    }
                    document.getElementById('metaBody').innerHTML =
                        '<table class="table table-sm table-striped mb-0"><tbody>' + rows + '</tbody></table>';
                    document.getElementById('metaJson').textContent = JSON.stringify(d.metadatos || {}, null, 2);
                })
                .catch(() => {
                    document.getElementById('metaBody').innerHTML =
                        '<div class="alert alert-danger">No se pudieron cargar los metadatos.</div>';
                });
        }

        // ── Revisión por pasos (elegir aprobar/rechazar) ──
        function revElegir(op) {
            document.getElementById('revPaso1').classList.add('d-none');
            document.getElementById('revAprobar').classList.toggle('d-none', op !== 'aprobar');
            document.getElementById('revRechazar').classList.toggle('d-none', op !== 'rechazar');
        }
        function revVolver() {
            const p1 = document.getElementById('revPaso1'); if (p1) p1.classList.remove('d-none');
            const a = document.getElementById('revAprobar'); if (a) a.classList.add('d-none');
            const r = document.getElementById('revRechazar'); if (r) r.classList.add('d-none');
        }

        // ── Vista previa del documento ──
        const VER_URL = '@Url.Action("Ver", "Documentos")';
        const DL_URL  = '@Url.Action("Download", "Documentos")';
        function previewMarkup(versionId, nombre) {
            const ext = (nombre || '').toLowerCase().split('.').pop();
            const url = VER_URL + '?versionId=' + versionId;
            if (ext === 'pdf')
                return `<iframe src="${url}" class="w-100 border rounded" style="height:75vh" title="Vista previa"></iframe>`;
            if (['png','jpg','jpeg','gif','webp','svg'].includes(ext))
                return `<div class="text-center border rounded p-2 bg-light" style="max-height:75vh;overflow:auto"><img src="${url}" class="img-fluid" alt="Vista previa"></div>`;
            if (ext === 'txt')
                return `<iframe src="${url}" class="w-100 border rounded bg-white" style="height:60vh" title="Vista previa"></iframe>`;
            const dl = DL_URL + '?versionId=' + versionId;
            return `<div class="alert alert-secondary mb-0">No hay vista previa para archivos <strong>.${ext}</strong> (Word, Excel, CAD, etc.). <a href="${dl}" class="alert-link"><i class="bi bi-download"></i> Descárgalo</a> para abrirlo en tu equipo.</div>`;
        }
        function verDocumento(versionId, nombre) {
            document.getElementById('previewTitulo').textContent = nombre || 'Documento';
            document.getElementById('previewBody').innerHTML = previewMarkup(versionId, nombre);
            document.getElementById('previewDescargar').href = DL_URL + '?versionId=' + versionId;
            new bootstrap.Modal(document.getElementById('previewModal')).show();
        }
        document.querySelectorAll('.js-ver').forEach(b =>
            b.addEventListener('click', () => verDocumento(b.dataset.versionId, b.dataset.nombre)));

        // Carga diferida del preview dentro del modal de revisión (solo al abrirlo).
        (function () {
            const rm = document.getElementById('revisarModal');
            if (!rm) return;
            rm.addEventListener('show.bs.modal', function () {
                const c = document.getElementById('revPreview');
                if (c && !c.dataset.loaded) {
                    c.innerHTML = previewMarkup(c.dataset.versionId, c.dataset.nombre);
                    c.dataset.loaded = '1';
                }
            });
        })();

        // ── Filtro del historial (estado + nº de versión) ──
        (function () {
            const est = document.getElementById('fEstado');
            const ver = document.getElementById('fVersion');
            const body = document.getElementById('histBody');
            const vacio = document.getElementById('histVacio');
            if (!body) return;
            function aplicar() {
                const e = (est ? est.value : '').toUpperCase();
                const v = (ver ? ver.value : '').toLowerCase().trim();
                let visibles = 0;
                body.querySelectorAll('tr').forEach(tr => {
                    const okE = !e || (tr.dataset.estado || '') === e;
                    const okV = !v || (tr.dataset.version || '').toLowerCase().includes(v);
                    const show = okE && okV;
                    tr.classList.toggle('d-none', !show);
                    if (show) visibles++;
                });
                if (vacio) vacio.classList.toggle('d-none', visibles > 0);
            }
            if (est) est.addEventListener('change', aplicar);
            if (ver) ver.addEventListener('input', aplicar);
        })();
    </script>
}
