@using Microsoft.AspNetCore.Mvc.Rendering
@model List<QualityDoc.Models.Domain.DocumentoVersion>
@{
    ViewData["Title"] = "Documentos";
    var areas = ViewBag.Areas as List<SelectListItem>;
    var q = ViewBag.Q as string;
    var areaId = ViewBag.AreaId as int?;
    var tipo = ViewBag.Tipo as string;
    int page = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    var vista = ViewBag.Vista as string ?? "vigentes";
    bool esLector = ViewBag.EsLector == true;
    bool puedeEditar = User.IsInRole("SUPERADMIN") || User.IsInRole("ADMIN") || User.IsInRole("AUTORIZADOR") || User.IsInRole("REVISOR") || User.IsInRole("CREADOR");
    var snippets = ViewBag.Snippets as Dictionary<int, QualityDoc.Services.Search.SearchHit>;
}
@functions {
    static string Badge(string estado) => estado switch
    {
        "APROBADO" => "success",
        "EN_REVISION" => "warning text-dark",
        "BORRADOR" => "secondary",
        "RECHAZADO" => "danger",
        "OBSOLETO" => "dark",
        _ => "light text-dark"
    };

    // Resalta el término buscado dentro del fragmento (escapando HTML).
    static Microsoft.AspNetCore.Html.IHtmlContent Resaltar(string? texto, string? termino)
    {
        if (string.IsNullOrEmpty(texto)) return new Microsoft.AspNetCore.Html.HtmlString("");
        var enc = System.Net.WebUtility.HtmlEncode(texto);
        if (!string.IsNullOrWhiteSpace(termino))
        {
            var pat = System.Text.RegularExpressions.Regex.Escape(System.Net.WebUtility.HtmlEncode(termino));
            enc = System.Text.RegularExpressions.Regex.Replace(enc, pat, m => $"<mark>{m.Value}</mark>",
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        }
        return new Microsoft.AspNetCore.Html.HtmlString(enc);
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Documentos</h3>
    @if (puedeEditar)
    {
        <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg"></i> Nuevo documento</a>
    }
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @(vista == "vigentes" ? "active" : "")" asp-action="Index" asp-route-vista="vigentes" asp-route-areaId="@areaId" asp-route-tipo="@tipo" asp-route-q="@q">
            <i class="bi bi-check-circle"></i> Vigentes
        </a>
    </li>
    @if (!esLector)
    {
        <li class="nav-item">
            <a class="nav-link @(vista == "proceso" ? "active" : "")" asp-action="Index" asp-route-vista="proceso" asp-route-areaId="@areaId" asp-route-tipo="@tipo" asp-route-q="@q">
                <i class="bi bi-hourglass-split"></i> En proceso
            </a>
        </li>
    }
</ul>

<form id="filtros" method="get" class="row g-2 mb-3">
    <input type="hidden" name="vista" value="@vista" />
    <div class="col-md-4">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input name="q" value="@q" class="form-control" placeholder="Buscar palabra en contenido y metadatos — MongoDB" />
        </div>
    </div>
    <div class="col-md-3">
        <select name="areaId" class="form-select" asp-items="areas">
            <option value="">— Todas las áreas —</option>
        </select>
    </div>
    <div class="col-md-2">
        <input name="tipo" value="@tipo" class="form-control" placeholder="Tipo (pdf, docx…)" />
    </div>
    <div class="col-md-2">
        <button class="btn btn-outline-primary w-100">Filtrar</button>
    </div>
    @if (!string.IsNullOrEmpty(q) || areaId != null || !string.IsNullOrEmpty(tipo))
    {
        <div class="col-md-1">
            <a asp-action="Index" asp-route-vista="@vista" class="btn btn-outline-secondary w-100" title="Limpiar"><i class="bi bi-x-lg"></i></a>
        </div>
    }
</form>

@if (vista == "proceso")
{
    <p class="text-muted small">Mostrando documentos <strong>en proceso</strong> (borradores y en revisión).</p>
}
else
{
    <p class="text-muted small">Mostrando solo documentos <strong>vigentes</strong> (aprobados).</p>
}
@if (!string.IsNullOrEmpty(q))
{
    <p class="text-muted small">Resultados de búsqueda en MongoDB para: <strong>@q</strong> (@ViewBag.Total)</p>
}

<div class="table-responsive">
    <table class="table table-hover align-middle bg-white">
        <thead class="table-light">
            <tr>
                <th>Título</th><th>Área</th><th>Versión</th><th>Estado</th><th>Tipo</th><th>Actualizado</th><th></th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="7" class="text-center text-muted py-4">No hay documentos.</td></tr>
        }
        @foreach (var v in Model)
        {
            <tr>
                <td><a asp-action="Details" asp-route-id="@v.DocumentoId">@v.Documento?.Titulo</a></td>
                <td>@v.Documento?.Area?.Nombre</td>
                <td><span class="badge bg-light text-dark border">@v.VersionTag</span>@(v.EsVigente ? " ✓" : "")</td>
                <td><span class="badge bg-@Badge(v.Estado)">@v.Estado</span></td>
                <td>@v.TipoArchivo</td>
                <td class="small text-muted">@v.CreadoEn.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@v.DocumentoId">Detalle</a>
                    @if (v.RutaArchivo != null)
                    {
                        <a class="btn btn-sm btn-outline-primary" asp-action="Download" asp-route-versionId="@v.Id">
                            <i class="bi bi-download"></i>
                        </a>
                    }
                </td>
            </tr>
            @if (snippets != null && snippets.TryGetValue(v.Id, out var hit) && !string.IsNullOrEmpty(hit.Snippet))
            {
                <tr class="table-light">
                    <td colspan="7" class="small py-2">
                        <i class="bi bi-search text-muted me-1"></i>
                        <span class="fst-italic">@Resaltar(hit.Snippet, q)</span>
                        @if (hit.Coincidencias > 0)
                        {
                            <span class="badge bg-secondary ms-2">@hit.Coincidencias coincidencia@(hit.Coincidencias == 1 ? "" : "s")</span>
                        }
                        @if (hit.Parrafo > 0)
                        {
                            <span class="text-muted ms-1">· párrafo @hit.Parrafo</span>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination pagination-sm">
            @for (int p = 1; p <= totalPages; p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-vista="@vista" asp-route-q="@q" asp-route-areaId="@areaId" asp-route-tipo="@tipo" asp-route-page="@p">@p</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        (function () {
            const f = document.getElementById('filtros');
            if (!f) return;
            // Área: se aplica al instante al seleccionar
            const sel = f.querySelector('select[name="areaId"]');
            if (sel) sel.addEventListener('change', () => f.submit());
            // Texto y tipo: se aplican con una pequeña pausa al escribir
            let t;
            f.querySelectorAll('input[name="q"], input[name="tipo"]').forEach(inp => {
                inp.addEventListener('input', () => { clearTimeout(t); t = setTimeout(() => f.submit(), 600); });
            });
        })();
    </script>
}
