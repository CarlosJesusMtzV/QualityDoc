@{
    var isAuth = User?.Identity?.IsAuthenticated == true;
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string Active(string c) => string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    bool esAdmin = User?.IsInRole("SUPERADMIN") == true || User?.IsInRole("ADMIN") == true;
    bool esSuper = User?.IsInRole("SUPERADMIN") == true;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · QualityDoc</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/theme.css" rel="stylesheet" />
    <script>
        // Aplica el tema guardado antes de pintar (evita parpadeo)
        (function () {
            var t = localStorage.getItem('qd-theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
</head>
<body>
@if (isAuth)
{
    <div class="qd-shell">
        <div class="qd-backdrop" id="qdBackdrop" onclick="qdCloseMenu()"></div>

        @* ── Sidebar ── *@
        <aside class="qd-sidebar" id="qdSidebar">
            <a class="qd-brand" asp-controller="Documentos" asp-action="Index">
                <i class="bi bi-file-earmark-check-fill"></i> QualityDoc
            </a>
            <nav class="qd-nav">
                <div class="nav-section">Principal</div>
                <a class="@Active("Documentos")" asp-controller="Documentos" asp-action="Index">
                    <i class="bi bi-folder2-open"></i> Documentos
                </a>
                <a class="@Active("Dashboard")" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-graph-up"></i> Panel
                </a>

                @if (esAdmin)
                {
                    <div class="nav-section">Administración</div>
                    <a class="@Active("Usuarios")" asp-controller="Usuarios" asp-action="Index">
                        <i class="bi bi-people"></i> Usuarios
                    </a>
                    <a class="@Active("Areas")" asp-controller="Areas" asp-action="Index">
                        <i class="bi bi-diagram-3"></i> Áreas
                    </a>
                    <a class="@Active("Auditoria")" asp-controller="Auditoria" asp-action="Index">
                        <i class="bi bi-shield-check"></i> Auditoría
                    </a>
                    <a class="@Active("Reportes")" asp-controller="Reportes" asp-action="Index">
                        <i class="bi bi-file-earmark-bar-graph"></i> Reportes
                    </a>
                    @if (esSuper)
                    {
                        <a class="@Active("Empresas")" asp-controller="Empresas" asp-action="Index">
                            <i class="bi bi-building"></i> Empresas
                        </a>
                    }
                }
            </nav>
            <div class="qd-sidebar-foot">
                <i class="bi bi-person-circle"></i> @User!.Identity!.Name
            </div>
        </aside>

        @* ── Área principal ── *@
        <div class="qd-main">
            <header class="qd-topbar">
                <button class="qd-iconbtn qd-menu-toggle" onclick="qdOpenMenu()" title="Menú"><i class="bi bi-list"></i></button>
                <h1 class="qd-title">@ViewData["Title"]</h1>
                <div class="ms-auto d-flex align-items-center gap-2">
                    @await Component.InvokeAsync("EmpresaSwitcher")
                    <button class="qd-iconbtn" onclick="qdToggleTheme()" title="Cambiar tema">
                        <i id="qdThemeIcon" class="bi bi-moon-stars"></i>
                    </button>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Auth" asp-action="Logout">
                        <i class="bi bi-box-arrow-right"></i> Salir
                    </a>
                </div>
            </header>

            <main class="qd-content">
                @if (TempData["Ok"] != null)
                {
                    <div class="alert alert-success alert-dismissible">@TempData["Ok"]<button class="btn-close" data-bs-dismiss="alert"></button></div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible">@TempData["Error"]<button class="btn-close" data-bs-dismiss="alert"></button></div>
                }
                @RenderBody()
            </main>

            <footer class="qd-footer text-center text-muted small">
                QualityDoc · Gestión Documental de Calidad
            </footer>
        </div>
    </div>
}
else
{
    @* ── Layout simple para login / páginas públicas ── *@
    <div class="d-flex flex-column min-vh-100 bg-body-tertiary">
        <main class="flex-fill d-flex align-items-center justify-content-center p-3">
            <div class="container">
                @RenderBody()
            </div>
        </main>
        <footer class="qd-footer text-center text-muted small">
            QualityDoc · Gestión Documental de Calidad
        </footer>
    </div>
}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function qdSyncThemeIcon() {
            var dark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
            var i = document.getElementById('qdThemeIcon');
            if (i) i.className = dark ? 'bi bi-sun' : 'bi bi-moon-stars';
        }
        function qdToggleTheme() {
            var html = document.documentElement;
            var next = html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-bs-theme', next);
            localStorage.setItem('qd-theme', next);
            qdSyncThemeIcon();
        }
        function qdOpenMenu() {
            document.getElementById('qdSidebar')?.classList.add('open');
            document.getElementById('qdBackdrop')?.classList.add('show');
        }
        function qdCloseMenu() {
            document.getElementById('qdSidebar')?.classList.remove('open');
            document.getElementById('qdBackdrop')?.classList.remove('show');
        }
        qdSyncThemeIcon();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
