@model QualityDoc.Models.ViewModels.UsuarioCreateViewModel
@{ ViewData["Title"] = "Nuevo usuario"; }

<h3 class="mb-3">Nuevo usuario</h3>
<div class="card shadow-sm"><div class="card-body">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Nombre</label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">Apellido</label>
                <input asp-for="Apellido" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Correo</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">Contraseña</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">Rol</label>
                <select asp-for="RolId" asp-items="Model.Roles" class="form-select">
                    <option value="">— Selecciona —</option>
                </select>
                <span asp-validation-for="RolId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">Área <span class="text-muted small">(obligatoria para Lector/Creador/Revisor)</span></label>
                <select asp-for="AreaId" asp-items="Model.Areas" class="form-select">
                    <option value="">— Sin área (Admin) —</option>
                </select>
                <span asp-validation-for="AreaId" class="text-danger small"></span>
            </div>
        </div>
        <div class="mt-3">
            <button class="btn btn-primary"><i class="bi bi-save"></i> Crear usuario</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div></div>
