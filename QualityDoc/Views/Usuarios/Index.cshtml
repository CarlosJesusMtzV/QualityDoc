@model List<QualityDoc.Models.Domain.Usuario>
@{ ViewData["Title"] = "Usuarios"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Usuarios</h3>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg"></i> Nuevo usuario</a>
</div>

<table class="table table-hover bg-white align-middle">
    <thead class="table-light"><tr><th>Nombre</th><th>Correo</th><th>Rol</th><th>Empresa</th><th>Activo</th></tr></thead>
    <tbody>
    @foreach (var u in Model)
    {
        <tr>
            <td>@u.NombreCompleto</td>
            <td>@u.Email</td>
            <td><span class="badge bg-secondary">@u.Rol?.Nombre</span></td>
            <td class="small text-muted">@u.Empresa?.Nombre</td>
            <td>@(u.Activo ? "Sí" : "No")</td>
        </tr>
    }
    </tbody>
</table>
